# Copiá este archivo a .env.local y completá los valores.
#   cp .env.local.example .env.local

# Backend Kodi (namespace /v1/admin/*). En local apunta al backend hermano.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Etiqueta de entorno (development | staging | production). Se usa en Sentry.
NEXT_PUBLIC_ENV=development

# Sentry DSN del panel. Vacío = el SDK queda inerte (no reporta en dev/local).
NEXT_PUBLIC_SENTRY_DSN=

# Vars de producción/CI (source maps, OpenAPI contra prod, credenciales e2e):
# ver la sección "Deploy" del README.md. No hacen falta para correr en local.
